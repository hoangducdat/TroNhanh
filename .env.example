# =============================================================
#  TroNhanh Backend — Template biến môi trường
#
#  HƯỚNG DẪN:
#  1. Copy file này thành .env: cp .env.example .env
#  2. Điền giá trị thực vào file .env
#  3. KHÔNG điền giá trị thực vào file này (.env.example)
#  File này được commit lên Git để làm template cho team.
# =============================================================

# Database MySQL
DB_HOST=localhost
DB_PORT=3306
DB_NAME=tronhanh_db
DB_USERNAME=
DB_PASSWORD=

# JWT
# Tạo secret: openssl rand -base64 64
JWT_SECRET=
JWT_EXPIRATION=86400000

# Upload file
UPLOAD_DIR=./uploads
UPLOAD_URL_PREFIX=http://localhost:8080/uploads

# Server
SERVER_PORT=8080
